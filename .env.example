# URL of the Express backend (backend/). Server-only - never exposed to the browser bundle,
# since all backend calls go through Next.js Route Handlers under app/api/**.
BACKEND_URL=http://localhost:3000

# Public Razorpay key id, used by the client-side checkout widget in a later stage.
# Safe to expose (it's the publishable key, not the secret).
NEXT_PUBLIC_RAZORPAY_KEY_ID=
