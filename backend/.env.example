# Postgres connection string used by config/database.js and the test suite (tests/helpers/db.js)
DATABASE_URL=postgresql://username:password@localhost:5432/electrolead
DB_POOL_MAX=10

# Server
PORT=3000
NODE_ENV=development
# Only matters for browser-facing CORS; with the Next.js server-side proxy in place this is rarely hit directly.
FRONTEND_URL=http://localhost:3001

# Auth (middleware/auth.js)
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRY=7d

# OTP (utils/otp.js) - email-based, not SMS
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=3

# Email (config/email.js) - set EMAIL_PROVIDER=resend to use Resend's SMTP relay, otherwise Gmail SMTP is used
EMAIL_PROVIDER=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
RESEND_API_KEY=

# Cloudinary (config/cloudinary.js) - stores KYC (PAN/GST) documents
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay (config/razorpay.js) - use test mode keys for now
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
